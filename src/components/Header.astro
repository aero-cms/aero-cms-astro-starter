---
import { cms } from '../lib/cms';
import { getComponentContent } from '../lib/cms-content';
import { siteHeaderSchema } from '../lib/schemas';
import { fetchMenu } from '@aero-cms/astro-sdk';

let menuItems: Array<{ id: number; label: string; url?: string }> = [];
let headerContent = await getComponentContent(cms, siteHeaderSchema);

try {
  const menu = await fetchMenu(cms, 'header');
  menuItems = menu.items ?? [];
} catch {
  menuItems = [];
}
---

<header class="site-header" data-cms-component="site-header">
  <div class="container">
    <a href="/" class="brand" data-cms-field="siteName">{headerContent.siteName}</a>
    <nav class="nav">
      {menuItems.map((item) => (
        <a href={item.url || '#'}>{item.label}</a>
      ))}
      <a href="/arama">Arama</a>
    </nav>
  </div>
</header>

<style>
  .brand { font-weight: 700; font-size: 1.125rem; }
</style>
