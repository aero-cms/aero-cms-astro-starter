---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCms } from '../lib/cms';
import { getRequestLang, cmsLangOptions } from '../lib/i18n';
import { fetchPage } from '@aero-cms/astro-sdk';

const lang = getRequestLang(Astro.cookies, Astro.url);
const cms = getCms(Astro.request);
const langOpts = cmsLangOptions(lang);
const slug = Astro.params.slug;

let page: Awaited<ReturnType<typeof fetchPage>> | null = null;
if (slug) {
  try {
    page = await fetchPage(cms, slug, langOpts);
  } catch {
    page = null;
  }
}
---

<BaseLayout title={page ? `${page.title} | AeroCMS` : 'Sayfa | AeroCMS'}>
  <article class="section">
    <div class="container article">
      {!page ? (
        <div class="error-box">Sayfa bulunamadı.</div>
      ) : (
        <>
          <h1>{page.title}</h1>
          <div set:html={page.blocks.map((b) => b.content).join('')} />
        </>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .article { max-width: 48rem; }
</style>
