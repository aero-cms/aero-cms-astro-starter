---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import { cms } from '../lib/cms';
import { getComponentContent } from '../lib/cms-content';
import { getRequestLang, cmsLangOptions } from '../lib/i18n';
import { eventsListSchema, heroSchema, newsListSchema } from '../lib/schemas';
import { fetchNews, fetchEvents } from '@aero-cms/astro-sdk';

const lang = getRequestLang(Astro.cookies);
const langOpts = cmsLangOptions(lang);

let haberler: Awaited<ReturnType<typeof fetchNews>> = [];
let etkinlikler: Awaited<ReturnType<typeof fetchEvents>> = [];
let heroContent = await getComponentContent(cms, heroSchema, langOpts);
let newsListContent = await getComponentContent(cms, newsListSchema, langOpts);
let eventsListContent = await getComponentContent(cms, eventsListSchema, langOpts);

try { haberler = await fetchNews(cms, { pageSize: 6, ...langOpts }); } catch {}
try { etkinlikler = await fetchEvents(cms, { pageSize: 4, ...langOpts }); } catch {}
---

<BaseLayout title="AeroCMS">
  <HeroSection content={heroContent} />

  <section class="section" data-cms-component="news-list">
    <div class="container">
      <div class="section-header">
        <h2 class="page-title" data-cms-field="sectionTitle">{newsListContent.sectionTitle}</h2>
        <a class="view-all" data-cms-field="viewAllText" href="/haberler">{newsListContent.viewAllText}</a>
      </div>
      {haberler.length ? (
        <div class="card-grid">
          {haberler.map((haber) => (
            <a class="card" href={`/haberler/${haber.id}`}>
              {haber.gorselUrl && <img src={haber.gorselUrl} alt={haber.baslik} />}
              <div class="card-body">
                <p class="meta">{new Date(haber.yayinTarihi).toLocaleDateString('tr-TR')}</p>
                <h3>{haber.baslik}</h3>
                <p>{haber.ozet}</p>
              </div>
            </a>
          ))}
        </div>
      ) : <p class="empty">Henüz haber bulunmuyor.</p>}
    </div>
  </section>

  <section class="section section-muted" data-cms-component="events-list">
    <div class="container">
      <div class="section-header">
        <h2 class="page-title" data-cms-field="sectionTitle">{eventsListContent.sectionTitle}</h2>
        <a class="view-all" data-cms-field="viewAllText" href="/etkinlikler">{eventsListContent.viewAllText}</a>
      </div>
      {etkinlikler.length ? (
        <div class="card-grid">
          {etkinlikler.map((e) => (
            <a class="card" href={`/etkinlikler/${e.id}`}>
              <div class="card-body">
                <h3>{e.baslik}</h3>
                <p>{e.konum}</p>
                <p>{e.aciklama}</p>
              </div>
            </a>
          ))}
        </div>
      ) : <p class="empty">Henüz etkinlik bulunmuyor.</p>}
    </div>
  </section>
</BaseLayout>

<style>
  .meta { font-size: 0.75rem; color: #6b7280; margin: 0 0 0.5rem; }
  h3 { margin: 0 0 0.5rem; }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .section-header .page-title { margin: 0; }
  .view-all { font-size: 0.875rem; color: #2563eb; text-decoration: none; }
  .view-all:hover { text-decoration: underline; }
</style>

<script>
  ['news-list', 'events-list'].forEach((componentKey) => {
    document.querySelectorAll(`[data-cms-component="${componentKey}"]`).forEach((section) => {
      section.addEventListener('cms-preview-update', (event) => {
        const fields = (event as CustomEvent<Record<string, string>>).detail;
        if (!fields) return;
        Object.entries(fields).forEach(([key, value]) => {
          const el = section.querySelector(`[data-cms-field="${key}"]`);
          if (el) el.textContent = value;
        });
      });
    });
  });
</script>
