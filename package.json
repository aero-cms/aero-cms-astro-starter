{
  "name": "aero-cms-astro-starter",
  "type": "module",
  "version": "1.0.0",
  "description": "Astro starter website for Aero CMS",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "cms:sync": "npx tsx node_modules/@aero-cms/core/dist/cli.js sync --schemas ./src/lib/schemas.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aero-cms/aero-cms-astro-starter.git"
  },
  "license": "MIT",
  "dependencies": {
    "@aero-cms/astro-sdk": "^1.1.2",
    "@aero-cms/core": "^1.1.0",
    "@astrojs/node": "^10.1.4",
    "astro": "^6.4.7"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
